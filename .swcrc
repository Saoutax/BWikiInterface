{
    "$schema": "https://swc.nodejs.cn/schema.json",
    "jsc": {
        "parser": {
            "syntax": "ecmascript",
            "dynamicImport": false
        },
        "target": "es5",
        "loose": false
    },
    "module": {
        "type": "commonjs"
    },
    "sourceMaps": false,
    "minify": false
}
